# Copy to .env and adjust. All variables are optional; defaults run a fully
# local, deterministic-capable stack.

# --- Local inference (Ollama) ---
VERITY_OLLAMA_BASE_URL=http://localhost:11434
VERITY_LLM_MODEL=llama3.1
VERITY_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VERITY_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
VERITY_EMBEDDING_DIM=384

# --- Retrieval tuning ---
VERITY_RETRIEVAL_TOP_K=20
VERITY_RRF_K=60
VERITY_RERANK_TOP_N=5
VERITY_MAX_AGENT_STEPS=4

# --- Storage (leave unset to use the in-memory store) ---
# VERITY_PG_DSN=postgresql://verity:verity@localhost:5432/verity

# --- Observability ---
VERITY_OTEL_CONSOLE_EXPORT=true
VERITY_SERVICE_NAME=verity
